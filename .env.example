# ============================================================
# PLUTO - Autonomous Cyber Defense Agent
# Environment Configuration Example
# ============================================================

# ── PLUTO AGENT CONFIGURATION ──
AGENT_MODE=dev
AI_PROVIDER=groq

# ── AI MODEL CONFIGURATION ──
GROQ_API_KEY=gsk_your_groq_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ── APPLICATION CONFIGURATION ──
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# ── CIVIC AI GOVERNANCE (Optional) ──
# CIVIC_API_KEY=your_civic_jwt_token_here
# CIVIC_MCP_URL=https://app.civic.com/hub/mcp?accountId=your_account_id

# ── FEATHERLESS AI (Optional) ──
# FEATHERLESS_API_KEY=your_featherless_api_key_here
# FEATHERLESS_ENDPOINT=https://api.featherless.ai/v1

# ── SANDBOX CONFIGURATION ──
SANDBOX_PORT=4000
SANDBOX_TIMEOUT=30000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# ── EXTENSION CONFIGURATION ──
EXTENSION_ENABLED=true
EXTENSION_AUTO_SCAN=true

# ── LOGGING CONFIGURATION ──
LOG_LEVEL=info
AGENT_DEBUG=false

# ── PERFORMANCE CONFIGURATION ──
AGENT_MEMORY_LIMIT=1000
SESSION_STORE_LIMIT=500
AI_ANALYSIS_TIMEOUT=30000

# ── DEVELOPMENT CONFIGURATION ──
DEV_MODE=true
GENERATE_MOCK_DATA=false
DEV_SKIP_VALIDATION=false

# ============================================================
# SETUP INSTRUCTIONS:
# 
# 1. Copy this file to .env or .env.local
# 2. Replace placeholder values with your actual API keys
# 3. Get Groq API key from: https://console.groq.com/keys
# 4. Get Civic AI credentials from: https://civic.com
# 5. Uncomment optional services as needed
# 
# MINIMUM REQUIRED:
# - GROQ_API_KEY
# 
# RECOMMENDED:
# - CIVIC_API_KEY and CIVIC_MCP_URL for full governance
# ============================================================